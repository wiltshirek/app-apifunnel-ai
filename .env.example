# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://...

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=unsigned-trust-relationship
MCP_ADMIN_KEY=your-admin-key-here
CRON_SECRET=your-cron-secret-here

# ── Firebase (Firestore for real-time signals + notifications) ────────────────
FIREBASE_PROJECT_ID=apifunnel-ai
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@apifunnel-ai.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── External services ──────────────────────────────────────────────────────────
# The Next.js web app — subagent runner calls /api/chat here
APP_BASE_URL=https://app.apifunnel.ai

# Graphiti / Learning graph service URL (optional — disables learning graph if unset)
GRAPHITI_SERVICE_URL=http://localhost:8001

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
