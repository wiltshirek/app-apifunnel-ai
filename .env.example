# ══════════════════════════════════════════════════════════════════════════════
# api-apifunnel-ai — unified env for both services
# Copy to .env and fill in real values
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────────────────────
# "development" or "production" — controls URL resolution, logging, CORS
NODE_ENV=development

# ── Database (Orchestration — Node/Mongoose) ──────────────────────────────────
# Database name is embedded in the URI path (e.g. /apifunnel)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/apifunnel?retryWrites=true&w=majority

# ── Database (Lakehouse — Python/Motor) ───────────────────────────────────────
# Same cluster, different database (mcp_code_execution_server)
# Falls back to MONGODB_URI if LAKEHOUSE_MONGODB_URI is not set
LAKEHOUSE_MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/mcp_code_execution_server?retryWrites=true&w=majority
LAKEHOUSE_DB_NAME=mcp_code_execution_server

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=unsigned-trust-relationship
MCP_ADMIN_KEY=your-admin-key-here
CRON_SECRET=change-me-set-same-in-vercel

# ── Firebase (Orchestration only — Firestore for notifications) ───────────────
FIREBASE_PROJECT_ID=apifunnel-ai
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@apifunnel-ai.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── External services ────────────────────────────────────────────────────────
APP_BASE_URL=https://app.apifunnel.ai
GRAPHITI_SERVICE_URL=http://localhost:8001

# ── Hetzner S3 (Lakehouse only) ──────────────────────────────────────────────
HETZNER_S3_ENDPOINT=https://hel1.your-objectstorage.com
HETZNER_S3_ACCESS_KEY=your-access-key
HETZNER_S3_SECRET=your-secret-key
HETZNER_S3_REGION=hel1
HETZNER_S3_ASSETS_BUCKET=mcp-lakehouse

# ── Ports ─────────────────────────────────────────────────────────────────────
PORT=3001
