# Caddy reverse proxy — handles TLS (Let's Encrypt) automatically.

# ── Webhook service (existing Docker container) ──────────────────
hooks.apifunnel.ai {
    reverse_proxy 172.17.1.2:3000

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        -Server
    }
}

# ── API platform services ────────────────────────────────────────
api.apifunnel.ai {
    # ── Lakehouse (Python :3002) ──────────────────────────────────
    handle /internal/assets/* {
        reverse_proxy localhost:3002
    }
    handle /api/v1/assets/* {
        reverse_proxy localhost:3002
    }

    # ── Orchestration (Node :3001) ────────────────────────────────
    handle /v1/* {
        reverse_proxy localhost:3001
    }

    # ── Graphiti adapter (optional, :8001) ────────────────────────
    handle /graphiti/* {
        uri strip_prefix /graphiti
        reverse_proxy localhost:8001
    }

    # ── Health checks (both services) ─────────────────────────────
    handle /health {
        reverse_proxy localhost:3001
    }
    handle /health/lakehouse {
        rewrite * /health
        reverse_proxy localhost:3002
    }

    # ── Catch-all → orchestration ─────────────────────────────────
    handle {
        reverse_proxy localhost:3001
    }
}
