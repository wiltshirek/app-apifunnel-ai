# Local development — HTTP only on :3000
:3000 {
    # ── Lakehouse (Python :3002) ──────────────────────────────────
    handle /internal/assets/* {
        uri replace /internal/assets /api/v1/assets
        reverse_proxy localhost:3002
    }
    handle /api/v1/assets {
        reverse_proxy localhost:3002
    }
    handle /api/v1/assets/* {
        reverse_proxy localhost:3002
    }

    # ── PR Bot (Python :3003) ─────────────────────────────────────
    handle /api/v1/prbot {
        reverse_proxy localhost:3003
    }
    handle /api/v1/prbot/* {
        reverse_proxy localhost:3003
    }

    # ── Repo Search (Python :3004) ─────────────────────────────────
    handle /api/v1/repo-search {
        reverse_proxy localhost:3004
    }
    handle /api/v1/repo-search/* {
        reverse_proxy localhost:3004
    }

    # ── Subagents (Node :3001) ────────────────────────────────────
    handle /v1/* {
        reverse_proxy localhost:3001
    }

    # ── Graphiti adapter (optional, :8001) ────────────────────────
    handle /graphiti/* {
        uri strip_prefix /graphiti
        reverse_proxy localhost:8001
    }

    # ── Health checks ─────────────────────────────────────────────
    handle /health {
        reverse_proxy localhost:3001
    }
    handle /health/lakehouse {
        rewrite * /health
        reverse_proxy localhost:3002
    }
    handle /health/prbot {
        rewrite * /health
        reverse_proxy localhost:3003
    }
    handle /health/reposearch {
        rewrite * /health
        reverse_proxy localhost:3004
    }

    # ── Catch-all → subagents (historical default for bare paths) ─
    handle {
        reverse_proxy localhost:3001
    }
}
